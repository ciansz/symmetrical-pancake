-- ── CamLock ─────────────────────────────────────────────────────
local camLockEnabled = false
local camLockTarget  = nil
local smoothness     = 0.5
local camLockKey     = Enum.KeyCode.Q

local function doCamLockToggle()
    if not camLockEnabled then return end
    if UserInputService:GetFocusedTextBox() then return end
    if camLockTarget then
        camLockTarget = nil
        Win:Notify({ Title="CamLock", Message="Unlocked", Type="info", Duration=2 })
    else
        local closestPlayer, closestDistance = nil, math.huge
        local mousePos = UserInputService:GetMouseLocation()
        for _, Player in pairs(Players:GetPlayers()) do
            if Player == LocalPlayer then continue end
            local character = Player.Character
            if character then
                local HRP = character:FindFirstChild("Head")
                if HRP then
                    local screenPos, onScreen = workspace.CurrentCamera:WorldToViewportPoint(HRP.Position)
                    if onScreen then
                        local distance = (Vector2.new(mousePos.X, mousePos.Y) - Vector2.new(screenPos.X, screenPos.Y)).Magnitude
                        if distance < closestDistance then closestDistance = distance; closestPlayer = Player end
                    end
                end
            end
        end
        camLockTarget = closestPlayer
        if closestPlayer then
            Win:Notify({ Title="CamLock", Message="Locked: "..closestPlayer.Name, Type="success", Duration=2 })
        end
    end
end

UserInputService.InputBegan:Connect(function(inp, gp)
    if gp then return end
    if inp.KeyCode == camLockKey then doCamLockToggle() end
end)

