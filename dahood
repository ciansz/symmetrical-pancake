-- CamLock
local camLockEnabled=false; local camLockTarget=nil; local smoothness=0.5; local camLockKey=Enum.KeyCode.Q

local function doCamLockToggle()
    if not camLockEnabled or UserInputService:GetFocusedTextBox() then return end
    if camLockTarget then
        camLockTarget=nil; Win:Notify({ Title="CamLock", Message="Unlocked", Type="info", Duration=2 })
    else
        local cp,cd=nil,math.huge; local mp=UserInputService:GetMouseLocation()
        for _,p in pairs(Players:GetPlayers()) do
            if p==LocalPlayer then continue end
            local c=p.Character
            if c then
                local h=c:FindFirstChild("Head")
                if h then
                    local sp,on=workspace.CurrentCamera:WorldToViewportPoint(h.Position)
                    if on then
                        local d=(Vector2.new(mp.X,mp.Y)-Vector2.new(sp.X,sp.Y)).Magnitude
                        if d<cd then cd=d; cp=p end
                    end
                end
            end
        end
        camLockTarget=cp
        if cp then Win:Notify({ Title="CamLock", Message="Locked: "..cp.Name, Type="success", Duration=2 }) end
    end
end
UserInputService.InputBegan:Connect(function(i,gp) if gp then return end; if i.KeyCode==camLockKey then doCamLockToggle() end end)

