-- ── Predict ───────────────────────────────────────────────────
local function predictPosition(targetRoot, mult)
    if not targetRoot then return targetRoot.Position end
    if targetRoot.Velocity.Magnitude > 700 then return targetRoot.Position end
    return targetRoot.Position + (targetRoot.Velocity * mult)
end

