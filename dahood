    end
end })
SecLegit:AddTextbox({ Name = "Smoothness", Placeholder = "0.5", Default = "0.5", ClearOnFocus = false, Callback = function(v)
    smoothness = tonumber(v) or 0.5
end })

RunService.RenderStepped:Connect(function()
    if camLockEnabled and camLockTarget then
        local character = camLockTarget.Character
        if character then
            local HRP = character:FindFirstChild("HumanoidRootPart")
            if HRP then
                local camera = workspace.CurrentCamera
                local currentCFrame = camera.CFrame
                local lookVector = (HRP.Position - currentCFrame.Position).Unit
                local smoothedLookVector = currentCFrame.LookVector:Lerp(lookVector, smoothness)
                camera.CFrame = CFrame.new(currentCFrame.Position, currentCFrame.Position + smoothedLookVector)
            end
        end
    end
end)

