-- Hitbox Expander
local hitboxSize=10; local hitboxColor=Color3.new(0,1,1)
local visualizeHitbox=false; local hitboxExpanderEnabled=false
local Client=LocalPlayer

local function removeVisuals(char)
    if not char then return end
    local HRP=char:FindFirstChild("HumanoidRootPart")
    if HRP then
        local o=HRP:FindFirstChild("HitboxOutline"); if o then o:Destroy() end
        local g=HRP:FindFirstChild("HitboxGlow");   if g then g:Destroy() end
    end
end
local function resetCharacter(char)
    if not char then return end
    local HRP=char:FindFirstChild("HumanoidRootPart")
    if HRP then HRP.Size=Vector3.new(2,1,2); HRP.Transparency=1; HRP.CanCollide=true; removeVisuals(char) end
end
local function handleCharacter(char)
    if not char or not hitboxExpanderEnabled then resetCharacter(char); return end
    local HRP=char:FindFirstChild("HumanoidRootPart") or char:WaitForChild("HumanoidRootPart",5)
    if not HRP then return end
    HRP.Size=Vector3.new(hitboxSize,hitboxSize,hitboxSize); HRP.Transparency=1; HRP.CanCollide=false
    if visualizeHitbox then
        local o=HRP:FindFirstChild("HitboxOutline")
        if not o then
            o=Instance.new("BoxHandleAdornment"); o.Name="HitboxOutline"; o.Adornee=HRP; o.Size=HRP.Size
            o.Transparency=0.8; o.ZIndex=10; o.AlwaysOnTop=true; o.Color3=hitboxColor; o.Parent=HRP
            local g=Instance.new("BoxHandleAdornment"); g.Name="HitboxGlow"; g.Adornee=HRP
            g.Size=HRP.Size+Vector3.new(0.1,0.1,0.1); g.Transparency=0.9; g.ZIndex=9
            g.AlwaysOnTop=true; g.Color3=hitboxColor; g.Parent=HRP
        else
            o.Size=HRP.Size; o.Color3=hitboxColor
            local g=HRP:FindFirstChild("HitboxGlow")
            if g then g.Size=HRP.Size+Vector3.new(0.1,0.1,0.1); g.Color3=hitboxColor end
        end
    else removeVisuals(char) end
end
local function handlePlayer(p)
    if p==Client then return end
    p.CharacterAdded:Connect(function(c) c:WaitForChild("HumanoidRootPart"); handleCharacter(c) end)
    if p.Character then handleCharacter(p.Character) end
end
for _,p in pairs(Players:GetPlayers()) do handlePlayer(p) end
