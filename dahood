            local t2=LocalPlayer.Character:FindFirstChildWhichIsA("Tool")
            if t2 and t2:FindFirstChild("Ammo") then ReplicatedStorage.MainEvent:FireServer("ShootGun",t2:FindFirstChild("Handle"),t2:FindFirstChild("Handle").CFrame.Position,char2.Head.Position,char2.Head,Vector3.new(0,0,-1)) end
            task.wait()
