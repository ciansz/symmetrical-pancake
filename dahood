local function getCurrentGun()
    local tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
    return tool and tool.Name or nil
end
local function getAmmoCount(gunName)
    local inv  = LocalPlayer.DataFolder and LocalPlayer.DataFolder.Inventory
    local ammo = inv and inv:FindFirstChild(gunName)
    return ammo and (tonumber(ammo.Value) or 0) or 0
end
local function buyAmmo(gunName)
    local Shop = Workspace:WaitForChild("Ignored"):WaitForChild("Shop")
    local AmmoMap = {
        ["[Revolver]"]="12 [Revolver Ammo] - $55",
        ["[AUG]"]="90 [AUG Ammo] - $87",
        ["[LMG]"]="200 [LMG Ammo] - $328",
        ["[Rifle]"]="5 [Rifle Ammo] - $273",
    }
    local itemName = AmmoMap[gunName]; if not itemName then return end
    local item = Shop:FindFirstChild(itemName); if not item then return end
    local savedCF  = LocalPlayer.Character.HumanoidRootPart.CFrame
    local curTool  = LocalPlayer.Character:FindFirstChildOfClass("Tool")
    if curTool then curTool.Parent = LocalPlayer.Backpack end
    LocalPlayer.Character.HumanoidRootPart.CFrame = item.Head.CFrame * CFrame.new(0, 3.2, 0)
    local cd = item:FindFirstChild("ClickDetector")
    if cd then for i=1,5 do fireclickdetector(cd); task.wait(0) end end
    if curTool then curTool.Parent = LocalPlayer.Character end
    LocalPlayer.Character.HumanoidRootPart.CFrame = savedCF
end
local function checkAmmoAndBuy()
    if not AutoAmmoEnabled then return end
    local gun = getCurrentGun(); if not gun then return end
    if getAmmoCount(gun) <= 0 then
        strafeWasEnabledBeforeAmmoBuy = strafeEnabled
        strafeEnabled = false
        if Core then Core:Destroy(); Core = nil end
        if BodyVelocity then BodyVelocity:Destroy(); BodyVelocity = nil end
        buyAmmo(gun)
        if strafeWasEnabledBeforeAmmoBuy then strafeEnabled = true end
    end
end

