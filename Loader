local messages     = { "Detecting Game", "Starting", "Loading Script" }
local messageIndex = 1
local animating    = true
local dotAnimating = false

local function animateDots(baseText)
    dotAnimating = true
    local dotStates = { ".", "..", "..." }
    local i = 1
    while dotAnimating do
        if not StatusLabel or not StatusLabel.Parent then break end
        StatusLabel.Text = baseText .. dotStates[i]
        i = i + 1
        if i > #dotStates then i = 1 end
        task.wait(0.22)
    end
end

local function showNextMessage()
    while animating do
        local base = messages[messageIndex]
        if not StatusLabel or not StatusLabel.Parent then break end

        StatusLabel.Position         = UDim2.new(0.5, -200, 0.5, 10)
        StatusLabel.TextTransparency = 1
        StatusLabel.Text             = base .. "."

        TweenService:Create(StatusLabel, TweenInfo.new(0.4, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
            Position         = UDim2.new(0.5, -200, 0.5, -5),
            TextTransparency = 0,
        }):Play()

        task.spawn(function() animateDots(base) end)
        task.wait(1.5)
        dotAnimating = false

        if not StatusLabel or not StatusLabel.Parent then break end
        TweenService:Create(StatusLabel, TweenInfo.new(0.35, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
            Position         = UDim2.new(0.5, -200, 0.5, -20),
            TextTransparency = 1,
        }):Play()

        task.wait(0.35)
        messageIndex = messageIndex + 1
        if messageIndex > #messages then messageIndex = 1 end
    end
end

task.delay(0.8, function()
    task.spawn(showNextMessage)
end)

local function fadeOutLoader()
    animating    = false
    dotAnimating = false
    local fadeOut = TweenInfo.new(0.65, Enum.EasingStyle.Quart, Enum.EasingDirection.In)
    if Title and Title.Parent        then TweenService:Create(Title,       fadeOut, {TextTransparency = 1}):Play() end
    if Glow and Glow.Parent          then TweenService:Create(Glow,        fadeOut, {TextTransparency = 1}):Play() end
    if StatusLabel and StatusLabel.Parent then TweenService:Create(StatusLabel, fadeOut, {TextTransparency = 1}):Play() end
    if Divider and Divider.Parent    then TweenService:Create(Divider,     fadeOut, {BackgroundTransparency = 1}):Play() end
    if Background and Background.Parent then TweenService:Create(Background,  fadeOut, {BackgroundTransparency = 1}):Play() end
    task.wait(0.7)
    if ScreenGui and ScreenGui.Parent then ScreenGui:Destroy() end
end

