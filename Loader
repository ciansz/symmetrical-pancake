    print("[Loader] Detected PlaceId: " .. tostring(placeId))
    print("[Loader] Loading script...")
    local ok, err = pcall(function()
        loadstring(game:HttpGet(url, true))() -- true = bypass cache
    end)
    if ok then
        print("[Loader] Loaded successfully!")
    else
        warn("[Loader] Error: " .. tostring(err))
    end
else
